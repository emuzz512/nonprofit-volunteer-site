/* ===================================
   Reset & Base Styles
   =================================== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --color-bg: #FAFAFA;
    --color-text: #1A1A1A;
    --color-accent: #FF6B6B;
    --color-accent-light: #FF8E8E;
    --color-gray: #666;
    --color-gray-light: #E5E5E5;
    --color-white: #FFFFFF;
    
    --font-primary: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
    
    --spacing-xs: 0.5rem;
    --spacing-sm: 1rem;
    --spacing-md: 2rem;
    --spacing-lg: 4rem;
    --spacing-xl: 6rem;
    --spacing-xxl: 8rem;
    
    --border-radius: 24px;
    --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

html {
    scroll-behavior: smooth;
    font-size: 16px;
}

body {
    font-family: var(--font-primary);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    overflow-x: hidden;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
}

/* ===================================
   Typography
   =================================== */
.section-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
}

.section-title.centered {
    text-align: center;
}

.section-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    color: var(--color-gray);
    text-align: center;
    margin-bottom: var(--spacing-lg);
    font-weight: 400;
}

/* ===================================
   Hero Section
   =================================== */
.hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding: var(--spacing-xxl) 0;
    overflow: hidden;
}

.hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
}

.hero-label {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: var(--color-text);
    color: var(--color-white);
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-md);
    animation: fadeInUp 0.8s ease-out;
}

.hero-title {
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.03em;
}

.title-line {
    display: block;
    animation: fadeInUp 0.8s ease-out backwards;
}

.title-line:nth-child(1) { animation-delay: 0.1s; }
.title-line:nth-child(2) { animation-delay: 0.2s; }
.title-line:nth-child(3) { animation-delay: 0.3s; }

.title-line.accent {
    color: var(--color-accent);
}

.hero-subtitle {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: var(--color-gray);
    margin-bottom: var(--spacing-lg);
    max-width: 600px;
    font-weight: 400;
    animation: fadeInUp 0.8s ease-out 0.4s backwards;
}

.cta-button {
    display: inline-block;
    padding: 1.25rem 3rem;
    background: var(--color-text);
    color: var(--color-white);
    text-decoration: none;
    border-radius: 50px;
    font-size: 1.125rem;
    font-weight: 600;
    transition: var(--transition);
    animation: fadeInUp 0.8s ease-out 0.5s backwards;
    position: relative;
    overflow: hidden;
}

.cta-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--color-accent);
    transition: var(--transition);
    z-index: -1;
}

.cta-button:hover::before {
    left: 0;
}

.cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}

.hero-decoration {
    position: absolute;
    top: 10%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-light) 100%);
    border-radius: 50%;
    opacity: 0.1;
    filter: blur(80px);
    animation: float 20s ease-in-out infinite;
}

/* ===================================
   Context Section
   =================================== */
.context {
    padding: var(--spacing-xxl) 0;
    background: var(--color-white);
}

.context-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
}

.context-text p {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
}

.context-text strong {
    font-weight: 600;
    color: var(--color-text);
}

.context-visual {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.stat-card {
    background: var(--color-bg);
    padding: var(--spacing-lg);
    border-radius: var(--border-radius);
    transition: var(--transition);
}

.stat-card.accent {
    background: var(--color-accent);
    color: var(--color-white);
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
}

.stat-number {
    font-size: clamp(3rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: var(--spacing-xs);
}

.stat-label {
    font-size: 1.125rem;
    font-weight: 500;
    opacity: 0.9;
}

/* ===================================
   Services Section
   =================================== */
.services {
    padding: var(--spacing-xxl) 0;
}

.services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
}

.service-card {
    background: var(--color-white);
    padding: var(--spacing-lg);
    border-radius: var(--border-radius);
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 0;
    background: var(--color-accent);
    transition: var(--transition);
}

.service-card:hover::before {
    height: 100%;
}

.service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
}

.service-icon {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-sm);
    display: block;
}

.service-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    line-height: 1.3;
}

.service-card p {
    color: var(--color-gray);
    line-height: 1.7;
    font-size: 1rem;
}

/* ===================================
   Audience Section
   =================================== */
.audience {
    padding: var(--spacing-xxl) 0;
    background: var(--color-white);
}

.audience-content {
    max-width: 800px;
    margin: 0 auto;
}

.audience-text {
    font-size: 1.125rem;
    line-height: 1.8;
}

.audience-text p {
    margin-bottom: var(--spacing-md);
}

.audience-list {
    list-style: none;
    margin: var(--spacing-md) 0;
}

.audience-list li {
    padding: var(--spacing-sm) 0;
    padding-left: 2rem;
    position: relative;
}

.audience-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
    font-size: 1.25rem;
}

.audience-note {
    font-style: italic;
    color: var(--color-gray);
    padding: var(--spacing-md);
    background: var(--color-bg);
    border-radius: var(--border-radius);
    border-left: 4px solid var(--color-accent);
}

/* ===================================
   Contact Section
   =================================== */
.contact {
    padding: var(--spacing-xxl) 0;
    background: var(--color-text);
    color: var(--color-white);
}

.contact-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
}

.contact .section-title {
    color: var(--color-white);
}

.contact-text {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-lg);
    opacity: 0.9;
}

.contact-methods {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
}

.contact-button {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: 1.25rem 2.5rem;
    background: var(--color-accent);
    color: var(--color-white);
    text-decoration: none;
    border-radius: 50px;
    font-size: 1.125rem;
    font-weight: 600;
    transition: var(--transition);
}

.contact-button.secondary {
    background: transparent;
    border: 2px solid var(--color-white);
}

.contact-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(255, 107, 107, 0.3);
}

.contact-button.secondary:hover {
    background: var(--color-white);
    color: var(--color-text);
    box-shadow: 0 10px 30px rgba(255, 255, 255, 0.2);
}

.button-icon {
    font-size: 1.5rem;
}

/* ===================================
   Footer
   =================================== */
.footer {
    padding: var(--spacing-lg) 0;
    background: var(--color-text);
    color: var(--color-gray-light);
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

/* ===================================
   Animations
   =================================== */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes float {
    0%, 100% {
        transform: translate(0, 0) rotate(0deg);
    }
    33% {
        transform: translate(30px, -30px) rotate(5deg);
    }
    66% {
        transform: translate(-20px, 20px) rotate(-5deg);
    }
}

.fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
}

.fade-in.visible {
    opacity: 1;
    transform: translateY(0);
}

/* ===================================
   Responsive Design
   =================================== */

/* ===================================
   Flip Card Styles
   =================================== */
.flip-card {
    perspective: 1000px;
    cursor: pointer;
    height: 100%;
    min-height: 500px;
}

.flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    text-align: left;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
}

.flip-card:hover .flip-card-inner,
.flip-card.flipped .flip-card-inner {
    transform: rotateY(180deg);
}

.flip-card-front,
.flip-card-back {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: var(--border-radius);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.flip-card-front {
    background: transparent;
}

.flip-card-back {
    background: var(--color-white);
    padding: var(--spacing-lg);
    transform: rotateY(180deg);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    overflow-y: auto;
}

.flip-prompt {
    text-align: center;
    padding: var(--spacing-md);
    background: var(--color-white);
    border-radius: var(--border-radius);
    color: var(--color-gray);
    font-size: 0.875rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
    transition: var(--transition);
}

.flip-card:hover .flip-prompt {
    background: var(--color-accent);
    color: var(--color-white);
    transform: scale(1.05);
}

.flip-icon {
    font-size: 1.5rem;
    display: inline-block;
    transition: var(--transition);
}

.flip-card:hover .flip-icon {
    transform: rotate(180deg);
}

.flip-card-back h3 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
}

.experience-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
}

.experience-item {
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-gray-light);
}

.experience-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
}

.experience-item strong {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.25rem;
}

.experience-item span {
    display: block;
    font-size: 0.875rem;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 0.5rem;
}

.experience-item p {
    font-size: 0.875rem;
    color: var(--color-gray);
    line-height: 1.5;
    margin: 0;
}

.credentials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-gray-light);
}

.credential {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-bg);
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

@media (max-width: 968px) {
    .context-grid {
        grid-template-columns: 1fr;
        gap: var(--spacing-lg);
    }
    
    .services-grid {
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }
    
    .contact-methods {
        flex-direction: column;
        align-items: stretch;
    }
}

@media (max-width: 640px) {
    :root {
        --spacing-lg: 3rem;
        --spacing-xl: 4rem;
        --spacing-xxl: 5rem;
    }
    
    .container {
        padding: 0 1.5rem;
    }
    
    .hero {
        min-height: 80vh;
    }
    
    .services-grid {
        grid-template-columns: 1fr;
    }
}
